# Copy to .env on the server (or set as environment variables in your host's panel)

# REQUIRED: persistent secret key — generate ONE long random string and keep it.
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
CLIPSCASH_SECRET=replace-with-a-64-char-random-hex-string

# Tells the app to disable debug, prefer HTTPS, secure cookies.
CLIPSCASH_ENV=prod

# Tells the app it is behind a reverse proxy (Hostinger/nginx/Cloudflare).
# Enables ProxyFix so request.remote_addr returns the real client IP.
CLIPSCASH_BEHIND_PROXY=1

# Set to 0 ONLY if you serve over plain HTTP (not recommended).
CLIPSCASH_HTTPS=1

# Optional: override the host:port for gunicorn.
# CLIPSCASH_HOST=0.0.0.0
# CLIPSCASH_PORT=5001
